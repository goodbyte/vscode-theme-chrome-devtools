{
  "$schema": "vscode://schemas/color-theme",
  "name": "Dark (Chrome DevTools)",
  "type": "dark",
  "colors": {
    "editor.background": "#1E1E1E",
    "editor.foreground": "#D4D4D4",
    "editor.inactiveSelectionBackground": "#3A3D41",
    "editorIndentGuide.background": "#404040",
    "editorIndentGuide.activeBackground": "#707070",
    "editor.selectionHighlightBackground": "#ADD6FF26",
    "list.dropBackground": "#383B3D",
    "activityBarBadge.background": "#007ACC",
    "sideBarTitle.foreground": "#BBBBBB",
    "input.placeholderForeground": "#A6A6A6",
    "menu.background": "#252526",
    "menu.foreground": "#CCCCCC",
    "statusBarItem.remoteForeground": "#FFF",
    "statusBarItem.remoteBackground": "#16825D",
    "ports.iconRunningProcessForeground": "#369432",
    "sideBarSectionHeader.background": "#0000",
    "sideBarSectionHeader.border": "#ccc3",
    "tab.lastPinnedBorder": "#ccc3",
    "list.activeSelectionIconForeground": "#FFF"
  },
  "tokenColors": [
    {
			"scope": [
				"meta.embedded",
				"source.groovy.embedded"
			],
			"settings": {
				"foreground": "#D4D4D4"
			}
		},
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
			"scope": "header",
			"settings": {
				"foreground": "#000080"
			}
		},
    {
      "scope": "comment",
      "settings": {
        "foreground": "#898989",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "comment.block.html",
      "settings": {
        "foreground": "#898989",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "meta.tag.metadata.doctype.html",
        "meta.tag.metadata.doctype.html entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#C0C0C0"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#f44747"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
			"scope": "markup.changed",
			"settings": {
				"foreground": "#569cd6"
			}
		},
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
				"entity.name.function.preprocessor",
        "entity.name.type",
        "entity.other.inherited-class",
        "keyword.operator.rest",
        "keyword.operator.spread",
        "meta.definition.function entity.name.function",
        "meta.definition.variable entity.name.function",
        "meta.parameters entity.name.function",
        "meta.parameters keyword.operator.optional",
        "meta.preprocessor",
        "punctuation.section.embedded",
        "variable",
        // HTML, XML
        "meta.tag",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json",
         // Markdown
        "markup.heading",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#5DB0D7"
      }
    },
    {
      "scope": [
        // HTML, XML
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml",
        "entity.other.attribute-name.localname.xml",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9BBBDC"
      }
    },
    {
      "scope": [
        "meta.embedded.assembly",
        "meta.preprocessor.string",
        "string",
        "string.regexp keyword",
        // Markdown
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#F29766"
      }
    },
    {
      "scope": [
				"source.coffee.embedded",
        // CSS
				"variable.other.less",
        "entity.name.tag.css",
        "entity.other.attribute-name",
        "entity.other.keyframe-offset",
        "meta.property-value",
        "meta.selector"
      ],
      "settings": {
        "foreground": "#FFA34F"
      }
    },
    {
      "scope": [
        // CSS
        "meta.property-name",
        "support.type.property-name.media",
        "support.type.vendored.property-name",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#35D4C7"
      }
    },
    {
      "scope": [
        "keyword.operator.type.annotation",
        "keyword.other.unit",
        "meta.return.type entity.name.type",
        "meta.type.annotation entity.name.type",
        "meta.type.parameters entity.name.type",
        "string.template variable",
        "variable.other.object",
        // CSS
        "constant.numeric.css",
        "constant.other",
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element",
        "keyword.operator.combinator",
        "keyword.operator.comparison.scss",
        "meta.property-list support.constant",
        "punctuation.section",
        "punctuation.separator",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": [
        // CSS
        "keyword.operator.logical.and.media",
        "keyword.operator.logical.not.media",
        "keyword.operator.logical.only.media",
        "meta.at-rule.import support.constant.property-value"
      ],
      "settings": {
        "foreground": "#07909A"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.optional",
        "keyword.operator.type",
        "meta.brace.angle.ts",
        "meta.method.declaration storage.type",
        "meta.object.member",
        "punctuation.definition.typeparameters.begin",
        "punctuation.definition.typeparameters.end",
        "storage.type.function.arrow",
        "support.function",
        "support.variable.property",
        "variable.object.property",
        "variable.other.property",
        // CSS
        "meta.property-value keyword.operator",
        // JSON
        "support.type.property-name.json",
        // PYTHON
        "meta.structure.dictionary.key.python"
      ],
      "settings": {
        "foreground": "#D2C057"
      }
    },
    {
      "scope": [
        "keyword",
        "meta.diff.header",
        "meta.method.declaration meta.var.expr storage.type",
        "meta.method.declaration storage.type.property",
        "punctuation.decorator",
        "storage",
        "variable.language.this",
      ],
      "settings": {
        "foreground": "#A38ECC"
      }
    },
    {
      "scope": [
        "constant",
        "meta.preprocessor.numeric",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json",
        // Markdown
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#A1F7B5"
      }
    },
    {
			"name": "Reset JavaScript string interpolation expression",
			"scope": [
				"meta.template.expression"
			],
			"settings": {
				"foreground": "#F29766"
			}
		}
  ]
}