{
  "$schema": "vscode://schemas/color-theme",
  "name": "Dark (Chrome DevTools)",
  "type": "dark",
  "colors": {
    // "editor.background": "#202124",
    "editor.foreground": "#eeffff",
    "editor.inactiveSelectionBackground": "#3A3D41",
    "editorIndentGuide.background": "#404040",
    "editorIndentGuide.activeBackground": "#707070",
    "editor.selectionHighlightBackground": "#ADD6FF26",
    "list.dropBackground": "#383B3D",
    "activityBarBadge.background": "#007ACC",
    "sideBarTitle.foreground": "#BBBBBB",
    "input.placeholderForeground": "#A6A6A6",
    "menu.background": "#252526",
    "menu.foreground": "#CCCCCC",
    "statusBarItem.remoteForeground": "#FFF",
    "statusBarItem.remoteBackground": "#16825D",
    "ports.iconRunningProcessForeground": "#369432",
    "sideBarSectionHeader.background": "#0000",
    "sideBarSectionHeader.border": "#ccc3",
    "tab.lastPinnedBorder": "#ccc3",
    "list.activeSelectionIconForeground": "#FFF",
    "editor.lineHighlightBorder": "#073D69",
    "editor.lineHighlightBackground": "#073D69"
  },
  "tokenColors": [
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#f44747"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#898989"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#569cd6"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#569cd6"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#569cd6"
      }
    },
    {
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": {
        "foreground": "#6A9955"
      }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#6796e6"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "scope": [
        // HTML, XML
        "meta.tag",
        "punctuation.definition.string.begin.html",
        "punctuation.definition.string.end.html",
        "punctuation.definition.string.begin.xml",
        "punctuation.definition.string.end.xml",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json",
        // TS
        "cast.expr",
        "entity.name.type.class",
        "entity.name.type.interface",
        "meta.definition.function entity.name.function",
        "meta.definition.variable entity.name.function",
        "meta.definition.variable",
        "variable.other.enummember",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#5DB0D7"
      }
    },
    {
      "scope": [
        // HTML, XML
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml",
        "entity.other.attribute-name.localname.xml",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9BBBD0"
      }
    },
    {
      "scope": [
        "string",
        "string keyword.control",
      ],
      "settings": {
        "foreground": "#F29766"
      }
    },
    {
      "scope": [
        // CSS
        "entity.other.keyframe-offset",
        "keyword.control.at-rule",
        "meta.property-value",
        "meta.selector",
        "support.function.url",
        "variable.css",
        "variable.parameter.keyframe-list",
        "variable.scss",
        "entity.other.attribute-name.scss",
        "source.css.less entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#FFA34F"
      }
    },
    {
      "scope": [
        // CSS
        "meta.property-name",
        "support.type.property-name.media",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#35D4C7"
      }
    },
    {
      "scope": [
        // CSS
        "constant.other",
        "constant.numeric.css",
        "entity.name.tag.wildcard",
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element",
        "punctuation.section.function.begin.bracket.round",
        "punctuation.section.function.end.bracket.round",
        "punctuation.separator.list.comma",
        "support.constant",
        "keyword.operator.combinator",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json",
        // TS
        "meta.type.declaration support.type.builtin",
        "meta.type.function variable.parameter",
        "new.expr entity.name.function",
        "string.template variable"
      ],
      "settings": {
        "foreground": "#eeffff"
      }
    },
    {
      "scope": [
        // CSS
        "keyword.operator.logical.and.media",
        "keyword.operator.logical.not.media",
        "keyword.operator.logical.only.media",
        "meta.at-rule.import support.constant.property-value"
      ],
      "settings": {
        "foreground": "#07909A"
      }
    },
    {
      "scope": [
        // CSS
        "string.quoted.double.css",
        "string.quoted.single.css",
        "string.quoted.double.scss",
        "string.quoted.single.scss",
        // JSON
        "support.type.property-name.json",
        // TS
        "entity.name.function",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.optional",
        "keyword.operator.type.ts",
        "meta.definition.method",
        "meta.method.declaration storage.type",
        "meta.object-literal.key",
        "punctuation.decorator",
        "punctuation.definition.typeparameters.begin",
        "punctuation.definition.typeparameters.end",
        "storage.type.function.arrow",
        "support.variable.property",
        "variable.object.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#E5D067"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.operator.expression",
        "keyword.operator.new",
        "storage.modifier",
        "storage.type",
        "storage.type.property",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#9C84CC"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.type.builtin",
        //JSON
        "meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#A1F7B5"
      }
    },
    {
      "scope": "support.function.git-rebase",
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "scope": "constant.sha.git-rebase",
      "settings": {
        "foreground": "#b5cea8"
      }
    }
  ]
}